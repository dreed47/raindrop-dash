# Get your API token from https://app.raindrop.io/settings/integrations
# Click "Create new app" → copy the Test Token
# Not required when DEMO_MODE=true
RAINDROP_TOKEN=your_api_token_here

# Optional: password-protect the dashboard
# Leave unset to disable authentication entirely
# DASHBOARD_PASSWORD=changeme

# Optional: read-only password — users logged in with this can browse but not add, edit, or delete
# Requires DASHBOARD_PASSWORD to also be set
# READONLY_PASSWORD=readonly_password_here

# Secret key used to sign session cookies
# REQUIRED if you set DASHBOARD_PASSWORD — without it sessions break on every restart
# Generate one with: python3 -c "import secrets; print(secrets.token_hex(32))"
# SECRET_KEY=

# How long to cache bookmarks in seconds (default: 3600 = 1 hour)
CACHE_TTL=3600

# Port the app listens on (default: 8080)
PORT=8080

# Demo mode — load sample bookmarks instead of fetching from Raindrop.io
# Useful for screenshots, testing the UI, or a no-credentials quickstart
# RAINDROP_TOKEN is not required when this is enabled
# DEMO_MODE=true

# Redis URL (default: redis://redis:6379/0 — uses the bundled Redis container)
# Override if you have your own Redis instance
# REDIS_URL=redis://localhost:6379/0
